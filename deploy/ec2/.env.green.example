# Domain (green environment)
APP_DOMAIN=green.videomaking.in
APP_EMAIL=ops@example.com

# App security
SESSION_SECRET=replace_with_long_random_secret
BHAGWAT_PASSWORD=replace_me

# AI/API keys
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
ASSEMBLYAI_API_KEY=

# S3 storage
S3_BUCKET=
S3_REGION=us-east-1
S3_OBJECT_PREFIX=ytgrabber-green
S3_SIGNED_URL_TTL_SEC=7200

# Optional yt-dlp bypass options (recommended in cloud environments)
YTDLP_PROXY=
YTDLP_POT_PROVIDER_URL=http://bgutil-provider:4416
YTDLP_COOKIES_BASE64=
YTDLP_PO_TOKEN=
YTDLP_VISITOR_DATA=

# Operational limits
MAX_CONCURRENT_CLIP_JOBS=3
MAX_CONCURRENT_SUBTITLE_JOBS=3
MAX_SUBTITLE_QUEUE_SIZE=40
RATE_LIMIT_BYPASS_IPS=

# Queue shadow mode (green validation)
YOUTUBE_QUEUE_SHADOW_ENABLED=true
# Queue primary mode currently covers download + clip-cut flows.
# Keep false until those paths are validated in your green environment.
YOUTUBE_QUEUE_PRIMARY_ENABLED=false
YOUTUBE_QUEUE_SHADOW_JOB_TYPES=download,clip-cut
YOUTUBE_QUEUE_PRIMARY_JOB_TYPES=download,clip-cut
YOUTUBE_QUEUE_REGION=us-east-1
YOUTUBE_QUEUE_JOB_TABLE=ytgrabber-green-jobs
YOUTUBE_BATCH_JOB_QUEUE=ytgrabber-green-job-queue
YOUTUBE_BATCH_JOB_DEFINITION=ytgrabber-green-worker-job

# Browser push notifications (generate once and keep stable)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com
