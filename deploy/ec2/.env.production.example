# Optional yt-dlp bypass options (recommended in cloud environments)
YTDLP_PROXY=
YTDLP_POT_PROVIDER_URL=http://bgutil-provider:4416
YTDLP_COOKIES_BASE64=
YTDLP_PO_TOKEN=
YTDLP_VISITOR_DATA=

# Operational limits
MAX_CONCURRENT_CLIP_JOBS=3
MAX_CONCURRENT_SUBTITLE_JOBS=3
MAX_SUBTITLE_QUEUE_SIZE=40
RATE_LIMIT_BYPASS_IPS=

# Browser push notifications (generate once and keep stable)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Video translator (GPU Batch worker)
YOUTUBE_QUEUE_REGION=us-east-1
YOUTUBE_QUEUE_JOB_TABLE=
TRANSLATOR_BATCH_JOB_QUEUE=
TRANSLATOR_BATCH_JOB_DEFINITION=
TRANSLATOR_BATCH_TIMEOUT_SECONDS=3000
TRANSLATOR_MAX_VIDEO_SIZE_BYTES=2147483648
TRANSLATOR_ALLOW_RUNTIME_MODEL_DOWNLOADS=1
