{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && export YTDLP_BIN=\"${YTDLP_BIN:-/home/runner/workspace/.local/bin/yt-dlp}\" && export S3_BUCKET=\"${S3_BUCKET:-malikaeditorr}\" && export S3_REGION=\"${S3_REGION:-us-east-1}\" && export S3_OBJECT_PREFIX=\"${S3_OBJECT_PREFIX:-ytgrabber-green}\" && export YTDLP_COOKIES_S3_KEY=\"${YTDLP_COOKIES_S3_KEY:-ytgrabber-green/secrets/ytdlp-cookies-base64.txt}\" && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-batch": "^3.1029.0",
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/client-lambda": "^3.1029.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@distube/ytdl-core": "^4.16.12",
    "@google/genai": "^1.46.0",
    "@google/generative-ai": "^0.24.1",
    "@types/ffmpeg-static": "^5.1.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "assemblyai": "^4.29.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pino": "^9",
    "pino-http": "^10",
    "serverless-http": "^3.2.0",
    "web-push": "^3.6.7",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
