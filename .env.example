# Required
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ytgrabber

# Server port
PORT=8080

# AI Features
# Google Gemini API key - required for "Fix with AI" subtitles and Bhagwat editor
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
# Tavily Search API key - optional. Powers the Content Manager's web_search tool
# (the model decides when to search). Without it, the tool is skipped gracefully.
TAVILY_API_KEY=

# AssemblyAI API key - required for Bhagwat audio transcription
ASSEMBLYAI_API_KEY=
E2B_API_KEY=

# Bhagwat Editor
# Password to unlock the Bhagwat AI Editor feature
BHAGWAT_PASSWORD=
# Max source clip/audio duration for Bhagwat renders, in seconds.
BHAGWAT_MAX_VIDEO_SEC=600
# Bound generated image count per render.
BHAGWAT_MAX_IMAGES_PER_JOB=100
# Keep local/dev at 1 to avoid Vertex Gemini RESOURCE_EXHAUSTED burst errors.
BHAGWAT_IMAGE_CONCURRENCY=1
BHAGWAT_IMAGE_SIZE=1K
IMAGE_GEN_TIMEOUT_MS=90000
BHAGWAT_IMAGE_RETRY_ATTEMPTS=5
BHAGWAT_IMAGE_RETRY_DELAY_MS=7000
# Current default project quota is often 2 image-gen requests/minute.
BHAGWAT_IMAGE_MIN_INTERVAL_MS=31000
# Default false: fail clearly instead of producing purple fallback-card videos.
BHAGWAT_ALLOW_FALLBACK_VISUALS=false

# Pita Ji Live workspace (separate themed workspace + login)
# Independent id+password gate (no Google sign-in). Stored server-side.
# Setting PITAJI_FEATURE_ENABLED=true exposes the workspace; everything below
# is required when it's on.
PITAJI_FEATURE_ENABLED=false
PITAJI_USERNAME=pitaji
PITAJI_PASSWORD=
# Reuses the existing YOUTUBE_QUEUE_JOB_TABLE by default (ytgrabber-green-jobs).
# Override only if you want a separate DDB table.
PITAJI_JOB_TABLE=
# Models for analysis + thumbnails.
# Default matches the rest of the current app (`gemini-3.5-flash`), but you can
# override to the cheaper 2.5 family if preferred (e.g. `gemini-2.5-flash`).
# Routed through Vertex automatically when GOOGLE_GENAI_USE_VERTEXAI=true.
PITAJI_ANALYSIS_MODEL=gemini-3.5-flash
# Image generation model for thumbnails (used in Phase 5).
PITAJI_THUMBNAIL_MODEL=gemini-3.1-flash-image-preview
# Audio split thresholds (in minutes). Default: 2 chunks at >40min, 3 at >120min.
PITAJI_AUDIO_CHUNK_2_THRESHOLD_MIN=40
PITAJI_AUDIO_CHUNK_3_THRESHOLD_MIN=120
# Overlap between adjacent chunks so a Q&A spanning the cut is not lost.
PITAJI_AUDIO_OVERLAP_SEC=30

# YouTube Bot-Detection Bypass (IMPORTANT for AWS/cloud server deployments)
# AWS EC2 and other datacenter IPs are blocked by YouTube's bot detection.
# Choose ONE of the following three methods to bypass this:
#
# METHOD 1 - Cookies (EASIEST, most reliable):
#   1. Install "Get cookies.txt LOCALLY" Chrome extension
#   2. Log into YouTube in your browser
#   3. Click the extension on youtube.com -> export cookies.txt
#   4. Run: base64 -w 0 cookies.txt  (Linux/Mac) or certutil -encode cookies.txt out.txt (Windows)
#   5. Paste the base64 output below
YTDLP_COOKIES_BASE64=

# METHOD 2 - po_token + visitor_data:
#   1. Install Node.js on any machine with a display (NOT your server)
#   2. Run: npx youtube-trusted-session-generator
#   3. Copy the po_token and visitor_data from the output
YTDLP_PO_TOKEN=
YTDLP_VISITOR_DATA=

# METHOD 3 - Residential proxy:
#   Route all yt-dlp traffic through a non-datacenter IP
#   Format: socks5://user:pass@host:port  or  http://host:port
YTDLP_PROXY=
YTDLP_POT_PROVIDER_URL=

# Runtime Limits / Queue (optional)
# Max concurrent clip-cut/download-clip workers (default 3)
MAX_CONCURRENT_CLIP_JOBS=3
# Dedicated Lambda fast-path policy. Slow/no-progress clips are handed to Batch.
LAMBDA_CLIP_HANDOFF_SAMPLE_MS=75000
LAMBDA_CLIP_HANDOFF_NO_PROGRESS_MS=120000
LAMBDA_CLIP_SAFE_BUDGET_MS=660000
LAMBDA_CLIP_COMPLETION_RESERVE_MS=120000
# Comma-separated IPs that bypass per-IP rate limits
RATE_LIMIT_BYPASS_IPS=

# Secret for internal server-to-server calls (AI copilot tools, Pita Ji, video
# editor). These calls hit the same in-process server via INTERNAL_API_BASE, so
# leaving this blank is safe - a strong random secret is generated at startup.
# Set it explicitly only if you need the value stable across separate processes.
INTERNAL_AGENT_SECRET=

# Public API keys (Developer tab)
# Admin-issued API keys unlock programmatic access to every service via a single
# bearer token:  Authorization: Bearer vms_live_xxx   (or  X-API-Key: vms_live_xxx)
# Keys + webhook registrations are stored in ACCESS_TABLE by default (no new infra).
# Optionally point them at a dedicated table instead:
API_KEYS_TABLE=
# Emails (besides admins) allowed to see the Developer tab and mint keys.
API_ACCESS_EMAILS=
# Default per-key rate limit (requests/minute). Per-key overrides are supported.
API_KEY_RATE_LIMIT_PER_MIN=120
# HMAC secret used to sign job-completion webhooks (X-VMS-Signature).
# Falls back to SESSION_SECRET when empty.
WEBHOOK_SIGNING_SECRET=
# NOTE: enable DynamoDB TTL on the `expiresAt` attribute of the key/access table
# so expiring keys and old webhook registrations are auto-removed.

# Browser push notifications (closed-tab/background completion alerts)
# Generate VAPID keys with:
# node --input-type=module -e "import webpush from 'web-push'; console.log(webpush.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# Diagnostics
# After deployment, visit /api/youtube/diagnostics to see what bypass methods
# are active and get recommendations if things aren't working.

# Optional
NODE_ENV=production
# Override path to built frontend static files (default: auto-detected)
# STATIC_DIR=/app/artifacts/yt-downloader/dist/public

# S3 storage for finished downloads/clips (recommended for production)
# Required for S3 mode:
S3_BUCKET=
# Optional (falls back to AWS_REGION, then us-east-1)
S3_REGION=
# Optional object key prefix (default: ytgrabber)
S3_OBJECT_PREFIX=ytgrabber
# Optional signed URL TTL in seconds (default 2 hours)
S3_SIGNED_URL_TTL_SEC=7200

# Video translator (GPU Batch worker)
YOUTUBE_QUEUE_REGION=us-east-1
YOUTUBE_QUEUE_JOB_TABLE=
TRANSLATOR_BATCH_JOB_QUEUE=
TRANSLATOR_BATCH_JOB_DEFINITION=
# Default 3000 seconds = 50 minutes
TRANSLATOR_BATCH_TIMEOUT_SECONDS=3000
# Default 2GB
TRANSLATOR_MAX_VIDEO_SIZE_BYTES=2147483648
# Keep runtime model/checkpoint downloads enabled unless the translator image bakes models.
TRANSLATOR_ALLOW_RUNTIME_MODEL_DOWNLOADS=1

# HeyGen tab (server-side proxy; never expose this key to the browser)
HEYGEN_API_KEY=
# Optional max upload size for HeyGen asset uploads, in bytes.
# Hard ceiling is 33554432 (32 MB) — HeyGen's /v3/assets endpoint rejects
# anything larger. AWS Lambda deploys should stay at/below 5242880 (5 MB) due
# to request payload limits; larger source videos must be supplied as a URL.
HEYGEN_UPLOAD_MAX_BYTES=5242880
# Optional Gemini model for HeyGen tab SRT generation
HEYGEN_SRT_MODEL=gemini-3.5-flash
# Optional outbound HeyGen API timeout in milliseconds
HEYGEN_REQUEST_TIMEOUT_MS=60000

# AI Video Studio — editor renders
# How a final render is dispatched in production (Lambda):
#   1. short renders  -> a worker Lambda is self-invoked (near-instant start)
#   2. long renders   -> AWS Batch/Fargate (no 15-min cap), when enabled
# Locally (not Lambda) renders always run in-process, no config needed.
#
# Allow Batch/Fargate for long renders (also the fallback when the worker
# Lambda is unavailable). Set true in production.
VIDEO_EDITOR_BATCH_ENABLED=false
# Lambda function to self-invoke for editor renders. Defaults to THIS function
# (AWS_LAMBDA_FUNCTION_NAME) in production, so usually leave blank.
VIDEO_EDITOR_WORKER_FUNCTION_NAME=
# Renders whose expected output exceeds this (seconds) go to Batch instead of
# the worker Lambda. Default 600 (10 min).
VIDEO_EDITOR_FARGATE_THRESHOLD_SEC=600
# Models used by the AI Video Studio agent + tools.
EDITOR_AGENT_MODEL=gemini-3.1-pro-preview
EDITOR_WATCH_MODEL=gemini-3-flash-preview
