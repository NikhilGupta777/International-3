# ── Required ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ytgrabber

# Server port
PORT=8080

# ── AI Features ────────────────────────────────────────────────────────────────
# Google Gemini API key — required for "Fix with AI" subtitles and Bhagwat editor
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# AssemblyAI API key — required for Bhagwat audio transcription
ASSEMBLYAI_API_KEY=

# ── Bhagwat Editor ─────────────────────────────────────────────────────────────
# Password to unlock the Bhagwat AI Editor feature
BHAGWAT_PASSWORD=

# ── Pita Ji Live workspace (separate themed workspace + login) ─────────────────
# Independent id+password gate (no Google sign-in). Stored server-side.
# Setting PITAJI_FEATURE_ENABLED=true exposes the workspace; everything below
# is required when it's on.
PITAJI_FEATURE_ENABLED=false
PITAJI_USERNAME=pitaji
PITAJI_PASSWORD=
# Reuses the existing YOUTUBE_QUEUE_JOB_TABLE by default (ytgrabber-green-jobs).
# Override only if you want a separate DDB table.
PITAJI_JOB_TABLE=
# Models for analysis + thumbnails — match the rest of the app (2.5 family).
# Used by the YouTube-direct (≤40 min) path AND each audio chunk in the
# Vertex AI long-video path. Override only if needed.
PITAJI_ANALYSIS_MODEL=gemini-2.5-flash
PITAJI_THUMBNAIL_MODEL=gemini-2.5-flash-image
# Audio split thresholds (in minutes). Default: 2 chunks at >40min, 3 at >120min.
PITAJI_AUDIO_CHUNK_2_THRESHOLD_MIN=40
PITAJI_AUDIO_CHUNK_3_THRESHOLD_MIN=120
# Overlap between adjacent chunks so a Q&A spanning the cut is not lost.
PITAJI_AUDIO_OVERLAP_SEC=30

# ── YouTube Bot-Detection Bypass (IMPORTANT for AWS/cloud server deployments) ──
# AWS EC2 and other datacenter IPs are blocked by YouTube's bot detection.
# Choose ONE of the following three methods to bypass this:
#
# METHOD 1 — Cookies (EASIEST, most reliable):
#   1. Install "Get cookies.txt LOCALLY" Chrome extension
#   2. Log into YouTube in your browser
#   3. Click the extension on youtube.com → export cookies.txt
#   4. Run: base64 -w 0 cookies.txt  (Linux/Mac) or certutil -encode cookies.txt out.txt (Windows)
#   5. Paste the base64 output below
YTDLP_COOKIES_BASE64=

# METHOD 2 — po_token + visitor_data:
#   1. Install Node.js on any machine with a display (NOT your server)
#   2. Run: npx youtube-trusted-session-generator
#   3. Copy the po_token and visitor_data from the output
YTDLP_PO_TOKEN=
YTDLP_VISITOR_DATA=

# METHOD 3 — Residential proxy:
#   Route all yt-dlp traffic through a non-datacenter IP
#   Format: socks5://user:pass@host:port  or  http://host:port
YTDLP_PROXY=
YTDLP_POT_PROVIDER_URL=

# â”€â”€ Runtime Limits / Queue (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Max concurrent clip-cut/download-clip workers (default 3)
MAX_CONCURRENT_CLIP_JOBS=3
# Comma-separated IPs that bypass per-IP rate limits
RATE_LIMIT_BYPASS_IPS=

# Browser push notifications (closed-tab/background completion alerts)
# Generate VAPID keys with:
# node --input-type=module -e "import webpush from 'web-push'; console.log(webpush.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# ── Diagnostics ────────────────────────────────────────────────────────────────
# After deployment, visit /api/youtube/diagnostics to see what bypass methods
# are active and get recommendations if things aren't working.

# ── Optional ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# Override path to built frontend static files (default: auto-detected)
# STATIC_DIR=/app/artifacts/yt-downloader/dist/public

# S3 storage for finished downloads/clips (recommended for production)
# Required for S3 mode:
S3_BUCKET=
# Optional (falls back to AWS_REGION, then us-east-1)
S3_REGION=
# Optional object key prefix (default: ytgrabber)
S3_OBJECT_PREFIX=ytgrabber
# Optional signed URL TTL in seconds (default: 7200 = 2 hours)
S3_SIGNED_URL_TTL_SEC=7200

# Video translator (GPU Batch worker)
YOUTUBE_QUEUE_REGION=us-east-1
YOUTUBE_QUEUE_JOB_TABLE=
TRANSLATOR_BATCH_JOB_QUEUE=
TRANSLATOR_BATCH_JOB_DEFINITION=
# Default 3000 seconds = 50 minutes
TRANSLATOR_BATCH_TIMEOUT_SECONDS=3000
# Default 2GB
TRANSLATOR_MAX_VIDEO_SIZE_BYTES=2147483648
# Keep runtime model/checkpoint downloads enabled unless the translator image bakes models.
TRANSLATOR_ALLOW_RUNTIME_MODEL_DOWNLOADS=1
