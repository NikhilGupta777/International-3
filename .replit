modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cliquer"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 API_PORT=8080 pnpm --filter @workspace/yt-downloader run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "S3_BUCKET=malikaeditorr S3_REGION=us-east-1 S3_OBJECT_PREFIX=ytgrabber-green YTDLP_COOKIES_S3_KEY=ytgrabber-green/secrets/ytdlp-cookies-base64.txt YTDLP_BIN=/home/runner/workspace/.pythonlibs/bin/yt-dlp PORT=8080 NODE_ENV=development pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 4200

[[ports]]
localPort = 5002
externalPort = 3003

[[ports]]
localPort = 5174
externalPort = 3002

[[ports]]
localPort = 5175
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "static"
build = ["pnpm", "--filter", "@workspace/yt-downloader", "run", "build"]
publicDir = "artifacts/yt-downloader/dist/public"

[userenv]

[userenv.shared]
S3_BUCKET = "malikaeditorr"
S3_REGION = "us-east-1"
S3_OBJECT_PREFIX = "ytgrabber-green"
YTDLP_COOKIES_S3_KEY = "ytgrabber-green/secrets/ytdlp-cookies-base64.txt"
AWS_REGION = "us-east-1"
NODE_ENV = "production"
YTDLP_BIN = "/home/runner/workspace/.pythonlibs/bin/yt-dlp"
