{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.mjs",
    "postinstall": "node scripts/optional-uv-sync.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@esbuild/win32-x64": "0.27.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1021.0",
    "@aws-sdk/client-ec2-instance-connect": "^3.1021.0",
    "@aws-sdk/client-ssm": "^3.1021.0",
    "node-ssh": "^13.2.1",
    "sshpk": "^1.18.0"
  }
}
